# Modelo ativo (LiteLLM format)
# Exemplos:
#   ollama/llama3.2
#   groq/llama-3.3-70b-versatile
#   anthropic/claude-sonnet-4-20250514
#   openai/gpt-4o
NULLAIN_MODEL=ollama/llama3.2

# Embeddings locais (busca semântica de fatos)
NULLAIN_EMBED_MODEL=ollama/nomic-embed-text

# --- Segurança da API local ---
# Quando definido, REST e WebSocket exigem o token.
# REST:  Authorization: Bearer <token>
# WS:    ws://127.0.0.1:8420/ws/chat?token=<token>
# Dashboard: defina VITE_NULLAIN_API_TOKEN com o mesmo valor.
# Vazio = auth desligada (apenas dev em localhost).
NULLAIN_API_TOKEN=

# Timeout do modal de confirmação (segundos)
NULLAIN_CONFIRM_TIMEOUT_SECONDS=120

# Workspace fixo (jail de arquivos + cwd do shell). Vazio = diretório atual no startup.
# NULLAIN_WORKSPACE=D:\projetos\meu-workspace

# Máximo de chars de tool_result no contexto do LLM (log completo permanece no SQLite)
NULLAIN_TOOL_RESULT_MAX_CHARS=8000

# Retenção de tool_logs e metrics (0 desliga o critério)
NULLAIN_LOG_RETENTION_DAYS=30
NULLAIN_LOG_MAX_ROWS=5000
NULLAIN_METRICS_RETENTION_DAYS=30
NULLAIN_METRICS_MAX_ROWS=5000

# Skills (NULLAIN-SKILLS) — pasta com */SKILL.md (vazio = ./skills)
# NULLAIN_SKILLS_DIR=./skills

# SQUADS — budget do orquestrador multi-agente
NULLAIN_SQUAD_MAX_ROLES=3
NULLAIN_SQUAD_MAX_ITERATIONS=5
NULLAIN_SQUAD_MAX_WALL_SECONDS=300

# --- Chaves de API (preencha só o provider que usar) ---

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# Groq (free tier)
GROQ_API_KEY=

# Google AI Studio (Gemini free)
GEMINI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# CircleCI (MCP — gere em https://app.circleci.com/settings/user/tokens)
CIRCLECI_TOKEN=

# --- Voz local (Fase 9) ---

# Whisper (STT)
NULLAIN_WHISPER_MODEL=base
NULLAIN_WHISPER_DEVICE=cpu
NULLAIN_WHISPER_COMPUTE_TYPE=int8

# Piper (TTS) — rode: uv run nullain voice-setup
NULLAIN_PIPER_VOICE=pt_BR-faber-medium
# NULLAIN_PIPER_MODEL_PATH=models/piper/pt_BR-faber-medium.onnx
NULLAIN_VOICE_RECORD_SECONDS=5