# Modelo ativo (LiteLLM format)
# Exemplos:
#   ollama/llama3.2
#   groq/llama-3.3-70b-versatile
#   anthropic/claude-sonnet-4-20250514
#   openai/gpt-4o
NULLAIN_MODEL=ollama/llama3.2

# Embeddings locais (busca semântica de fatos)
NULLAIN_EMBED_MODEL=ollama/nomic-embed-text

# --- Chaves de API (preencha só o provider que usar) ---

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# Groq (free tier)
GROQ_API_KEY=

# Google AI Studio (Gemini free)
GEMINI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# CircleCI (MCP — gere em https://app.circleci.com/settings/user/tokens)
CIRCLECI_TOKEN=

# --- Voz local (Fase 9) ---

# Whisper (STT)
NULLAIN_WHISPER_MODEL=base
NULLAIN_WHISPER_DEVICE=cpu
NULLAIN_WHISPER_COMPUTE_TYPE=int8

# Piper (TTS) — rode: uv run nullain voice-setup
NULLAIN_PIPER_VOICE=pt_BR-faber-medium
# NULLAIN_PIPER_MODEL_PATH=models/piper/pt_BR-faber-medium.onnx
NULLAIN_VOICE_RECORD_SECONDS=5