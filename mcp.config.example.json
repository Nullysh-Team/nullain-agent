{
  "servers": [
    {
      "name": "test",
      "transport": "stdio",
      "command": "python",
      "args": ["scripts/minimal_mcp_server.py"],
      "env": {}
    },
    {
      "name": "github",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  ]
}